    const normalizeLang = (value) => (value === "en" ? "en" : "zh");
    const getSavedLang = () => normalizeLang(localStorage.getItem("nte-lang") || "zh");

    function applyTranslations(lang) {
      const table = translations[lang] || translations.zh;
      document.documentElement.lang = lang === "en" ? "en" : "zh-CN";
      document.documentElement.dataset.lang = lang;

      document.querySelectorAll("[data-i18n]").forEach((node) => {
        const value = table[node.dataset.i18n];
        if (value) node.textContent = value;
      });

      [
        ["data-i18n-placeholder", "placeholder"],
        ["data-i18n-title", "title"],
        ["data-i18n-aria-label", "aria-label"],
        ["data-i18n-alt", "alt"]
      ].forEach(([dataName, attrName]) => {
        document.querySelectorAll(`[${dataName}]`).forEach((node) => {
          const key = node.getAttribute(dataName);
          const value = key ? table[key] : "";
          if (value) node.setAttribute(attrName, value);
        });
      });

      const label = document.getElementById("languageToggleLabel");
      if (label) label.textContent = lang === "en" ? "中" : "EN";
      window.dispatchEvent(new CustomEvent("nte-language-change", { detail: { lang } }));
    }

    function setLang(lang) {
      const nextLang = normalizeLang(lang);
      localStorage.setItem("nte-lang", nextLang);
      applyTranslations(nextLang);
    }

    window.__setNteLang = setLang;
    document.addEventListener("DOMContentLoaded", () => {
      const initialLang = getSavedLang();
      applyTranslations(initialLang);
      document.getElementById("languageToggle")?.addEventListener("click", () => {
        const currentLang = normalizeLang(document.documentElement.dataset.lang);
        setLang(currentLang === "en" ? "zh" : "en");
      });
    });
  })();
