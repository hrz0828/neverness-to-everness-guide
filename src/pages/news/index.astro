---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { newsItems } from "../../data/news";
import { newsEnglish } from "../../data/contentEnglish";

const items = [...newsItems].sort((a, b) => b.date.localeCompare(a.date));
const [featured, ...restItems] = items;
const categories = [...new Set(items.map((item) => item.category || "攻略"))];
const categoriesEn = [...new Set(items.map((item) => newsEnglish[item.id]?.category || "Guide"))];
---

<BaseLayout
  title="最新攻略/版本动态 | 异环攻略站"
  description="异环最新攻略、版本动态、异象委托、地图跑图、搜打撤玩法与收集路线列表。"
  jsonLd={{ "@context": "https://schema.org", "@type": "CollectionPage", name: "异环最新攻略/版本动态" }}
>
  <header>
    <p class="text-sm font-semibold text-neon">Neverness to Everness / NTE</p>
    <h1 class="mt-2 text-3xl font-black text-zinc-950 dark:text-white"><span class="lang-zh">最新攻略/版本动态</span><span class="lang-en">Latest Guides / Version Updates</span></h1>
    <p class="lang-zh mt-3 max-w-3xl text-sm leading-7 text-zinc-600 dark:text-zinc-400">
      汇总异环 2026 年 5 月下旬后的版本前瞻、角色养成、地图探索、异象委托、搜打撤玩法与资源规划攻略，适合开荒查路线、补收集和快速定位玩法重点。
    </p>
    <p class="lang-en mt-3 max-w-3xl text-sm leading-7 text-zinc-600 dark:text-zinc-400">
      Version previews, character builds, map routes, anomaly commissions, extraction-mode guides and resource planning for NTE players after late May 2026.
    </p>
    <div class="mt-5 flex flex-wrap gap-2">
      {categories.map((category) => (
        <span class="lang-zh rounded-md border border-zinc-200 bg-white px-3 py-1 text-xs font-semibold text-zinc-600 dark:border-line dark:bg-white/[0.04] dark:text-zinc-300">
          {category}
        </span>
      ))}
      {categoriesEn.map((category) => (
        <span class="lang-en rounded-md border border-zinc-200 bg-white px-3 py-1 text-xs font-semibold text-zinc-600 dark:border-line dark:bg-white/[0.04] dark:text-zinc-300">
          {category}
        </span>
      ))}
    </div>
  </header>

  {
    featured && (
      <a
        href={`/news/${featured.id}/`}
        class="mt-8 grid overflow-hidden rounded-lg border border-teal-300 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:border-teal-500 dark:border-neon/50 dark:bg-panel/80 dark:shadow-glow lg:grid-cols-[1.15fr_0.85fr]"
      >
        <img
          src={featured.image}
          alt={`异环攻略封面-${featured.title}`}
          class="h-full min-h-72 w-full object-cover"
          loading="eager"
        />
        <div class="flex flex-col justify-center p-5 sm:p-7">
          <p class="text-xs font-semibold text-teal-600 dark:text-neon"><span class="lang-zh">{featured.category || "最新攻略"}</span><span class="lang-en">{newsEnglish[featured.id]?.category || "Latest Guide"}</span></p>
          <h2 class="mt-3 text-2xl font-black leading-tight text-zinc-950 transition hover:text-teal-600 dark:text-white dark:hover:text-blue-400">
            <span class="lang-zh">{featured.title}</span><span class="lang-en">{newsEnglish[featured.id]?.title}</span>
          </h2>
          <div class="mt-3 flex flex-wrap gap-3 text-xs text-zinc-500">
            <span>{featured.date}</span>
            {featured.readTime && <span><span class="lang-zh">{featured.readTime}</span><span class="lang-en">{newsEnglish[featured.id]?.readTime || featured.readTime}</span></span>}
          </div>
          <p class="mt-4 text-sm leading-7 text-zinc-600 dark:text-zinc-400"><span class="lang-zh">{featured.excerpt}</span><span class="lang-en">{newsEnglish[featured.id]?.excerpt}</span></p>
          <span class="mt-5 inline-flex w-fit rounded-lg bg-teal-500 px-4 py-2 text-sm font-bold text-white dark:bg-neon dark:text-black">
            <span class="lang-zh">阅读重点攻略</span><span class="lang-en">Read Featured Guide</span>
          </span>
        </div>
      </a>
    )
  }

  <section class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {
      restItems.map((item) => (
        <a
          href={`/news/${item.id}/`}
          class="group block rounded-lg border border-zinc-200 bg-white p-4 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-teal-400 dark:border-line dark:bg-panel/80 dark:shadow-none dark:hover:border-neon"
        >
          <img
            src={item.image}
            alt={`异环攻略封面-${item.title}`}
            class="aspect-[16/9] w-full rounded-lg object-cover"
            loading="lazy"
          />
          <div class="mt-4 flex flex-wrap items-center gap-2 text-xs text-zinc-500">
            <span>{item.date}</span>
            <span class="rounded-md border border-zinc-200 px-2 py-0.5 dark:border-line"><span class="lang-zh">{item.category || "攻略"}</span><span class="lang-en">{newsEnglish[item.id]?.category || "Guide"}</span></span>
            {item.readTime && <span><span class="lang-zh">{item.readTime}</span><span class="lang-en">{newsEnglish[item.id]?.readTime || item.readTime}</span></span>}
          </div>
          <h2 class="mt-2 font-bold text-zinc-950 transition group-hover:text-teal-600 dark:text-white dark:group-hover:text-blue-400">
            <span class="lang-zh">{item.title}</span><span class="lang-en">{newsEnglish[item.id]?.title}</span>
          </h2>
          <p class="mt-2 text-sm leading-6 text-zinc-600 dark:text-zinc-400"><span class="lang-zh">{item.excerpt}</span><span class="lang-en">{newsEnglish[item.id]?.excerpt}</span></p>
        </a>
      ))
    }
  </section>
</BaseLayout>
