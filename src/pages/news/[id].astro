---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { newsItems } from "../../data/news";

export function getStaticPaths() {
  return newsItems.map((item) => ({ params: { id: item.id }, props: { item } }));
}

const { item } = Astro.props;
const guide = item.guide;
---

<BaseLayout
  title={`${item.title} | 异环攻略`}
  description={item.excerpt}
  ogImage={item.image}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    headline: item.title,
    datePublished: item.date,
    author: { "@type": "Organization", name: item.author },
    image: item.image
  }}
>
  <article class="mx-auto max-w-4xl">
    <nav class="text-sm text-zinc-500">
      <a href="/" class="hover:text-neon">首页</a>
      <span class="mx-2">/</span>
      <span>攻略</span>
      <span class="mx-2">/</span>
      <span class="text-zinc-300">正文</span>
    </nav>

    <header class="mt-6">
      <p class="text-sm font-semibold text-neon">{item.category || "最新攻略"}</p>
      <h1 class="mt-2 text-3xl font-black leading-tight text-zinc-950 dark:text-white sm:text-5xl">{item.title}</h1>
      <div class="mt-4 flex flex-wrap gap-3 text-sm text-zinc-500">
        <span>发布时间：{item.date}</span>
        <span>作者：{item.author}</span>
        {item.readTime && <span>阅读时间：{item.readTime}</span>}
      </div>
    </header>

    <img
      src={item.image}
      alt={`异环攻略配图-${item.title}`}
      class="mt-8 aspect-[16/9] w-full rounded-xl object-cover"
      loading="eager"
    />

    {
      item.gallery?.length ? (
        <section class="mt-6 grid gap-3 sm:grid-cols-2">
          {item.gallery.map((image) => (
            <figure class="overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
              <img src={image.src} alt={image.alt} class="aspect-[16/9] w-full object-cover" loading="lazy" />
              {image.caption && (
                <figcaption class="px-3 py-2 text-xs leading-5 text-zinc-500 dark:text-zinc-400">{image.caption}</figcaption>
              )}
            </figure>
          ))}
        </section>
      ) : null
    }

    {
      guide ? (
        <div class="mt-8 space-y-8">
          <section class="rounded-lg border border-teal-200 bg-white p-5 shadow-sm dark:border-neon/30 dark:bg-neon/10 dark:shadow-none">
            <p class="text-xs font-semibold uppercase text-teal-600 dark:text-neon">攻略速览</p>
            <p class="mt-3 text-base leading-8 text-zinc-700 dark:text-zinc-100">{guide.overview}</p>
          </section>

          <section>
            <h2 class="text-2xl font-black text-zinc-950 dark:text-white">前置条件与接取方式</h2>
            <div class="mt-4 grid gap-3 md:grid-cols-3">
              {guide.requirements.map((requirement) => (
                <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
                  <p class="text-sm font-semibold text-teal-600 dark:text-neon">{requirement.label}</p>
                  <p class="mt-2 text-sm leading-6 text-zinc-700 dark:text-zinc-300">{requirement.value}</p>
                </div>
              ))}
            </div>
          </section>

          <section>
            <div class="flex flex-wrap items-end justify-between gap-3">
              <h2 class="text-2xl font-black text-zinc-950 dark:text-white">{guide.stepsTitle || "攻略流程"}</h2>
              <p class="text-sm text-zinc-500">{guide.stepsNote || "按顺序执行，避免重复跑图"}</p>
            </div>
            <div class="mt-4 space-y-3">
              {guide.steps.map((step, index) => (
                <div class="flex gap-4 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
                  <div class="grid size-9 shrink-0 place-items-center rounded-md bg-teal-500 text-sm font-black text-white dark:bg-neon dark:text-black">
                    {index + 1}
                  </div>
                  <div>
                    <h3 class="font-bold text-zinc-950 dark:text-white">{step.title}</h3>
                    <p class="mt-1 text-sm font-semibold text-amber dark:text-amber">{step.action}</p>
                    <p class="mt-2 text-sm leading-6 text-zinc-700 dark:text-zinc-400">{step.detail}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>

          <section class="grid gap-4 lg:grid-cols-[1.25fr_0.75fr]">
            <div class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
              <p class="text-sm font-semibold text-signal">{guide.challengeLabel || "BOSS战"}</p>
              <h2 class="mt-2 text-2xl font-black text-zinc-950 dark:text-white">{guide.boss.name}</h2>
              <p class="mt-3 text-sm leading-7 text-zinc-700 dark:text-zinc-300">{guide.boss.summary}</p>
              <ul class="mt-4 space-y-3">
                {guide.boss.tips.map((tip) => (
                  <li class="flex gap-3 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
                    <span class="mt-2 size-1.5 shrink-0 rounded-full bg-signal" />
                    <span>{tip}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
              <p class="text-sm font-semibold text-teal-600 dark:text-neon">完成奖励</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {guide.rewards.map((reward) => (
                  <span class="rounded-md border border-teal-200 bg-teal-50 px-3 py-2 text-sm text-zinc-800 dark:border-neon/30 dark:bg-neon/10 dark:text-zinc-100">
                    {reward}
                  </span>
                ))}
              </div>
              <p class="mt-5 text-sm leading-7 text-zinc-700 dark:text-zinc-400">{guide.closing}</p>
            </div>
          </section>

          {item.paragraphs?.length ? (
            <section class="prose max-w-none">
              <h2>完整解析</h2>
              {item.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            </section>
          ) : null}
        </div>
      ) : (
        <div class="prose mt-8 max-w-none">
          {item.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      )
    }

    <a
      href="/"
      class="mt-10 inline-flex rounded-lg border border-neon/60 px-4 py-2 text-sm font-semibold text-neon transition hover:bg-neon hover:text-black"
    >
      返回首页
    </a>
  </article>
</BaseLayout>
