---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const guideOrder = ["beginner", "team-building", "anomaly-commission-checklist"];
const getGuideOrder = (slug) => {
  const index = guideOrder.indexOf(slug);
  return index === -1 ? guideOrder.length : index;
};
const guides = [...await getCollection("guides")].sort((a, b) => getGuideOrder(a.slug) - getGuideOrder(b.slug));
const featuredGuide = guides.find((guide) => guide.slug === "beginner") ?? guides[0];

const systems = [
  {
    key: "city",
    tagKey: "explore",
    name: "城市异象探索",
    tag: "探索必看",
    image: "/images/news/area-illusion-town.jpg",
    alt: "异环城市异象探索街区游戏截图",
    tips: [
      "优先解锁城区传送点，再回头清理屋顶、地下通道和高架夹层的隐藏收集。",
      "夜间巡逻和雨后街区更容易遇到高威胁异象委托，建议提前准备治疗位和控场角色。",
      "遇到空间扭曲、信号噪点或路灯异常闪烁时，先沿街角、屋顶入口和桥下层寻找调查交互点。"
    ],
    tipsEn: [
      "Unlock district teleports first, then return for hidden collectibles on rooftops, underground paths and elevated layers.",
      "Night patrols and rainy districts are more likely to surface high-threat anomaly commissions, so prepare healing and control before entering.",
      "When space distortion, signal noise or abnormal streetlights appear, check street corners, rooftop access points and under-bridge layers for investigation prompts."
    ]
  },
  {
    key: "car",
    tagKey: "hot",
    name: "改装车系统",
    tag: "热门机制",
    image: "/images/news/area-new-herland.jpg",
    alt: "异环改装车系统城市道路游戏截图",
    tips: [
      "开荒期优先升级操控、加速和耐久，能显著提升跑图效率和追逐任务容错。",
      "城区探索建议携带高机动配置，材料循环路线则更适合续航和稳定性配件。",
      "部分追逐、限时取样和异常封锁会限制步行路径，改装车可作为快速脱离异常区域的关键工具。"
    ],
    tipsEn: [
      "During progression, upgrade handling, acceleration and durability first to improve travel efficiency and chase-task tolerance.",
      "Use high-mobility setups for city exploration, and endurance or stability parts for material routes.",
      "Some chase tasks, timed sampling routes and abnormal lockdowns restrict walking routes, so tuned vehicles can be the safest way to exit quickly."
    ]
  },
  {
    key: "events",
    tagKey: "advanced",
    name: "异象委托追踪",
    tag: "进阶路线",
    image: "/images/news/city-gameplay.jpg",
    alt: "异环都市街道异象委托追踪游戏截图",
    tips: [
      "先记录异象委托的触发时段、天气和前置交互，避免反复跑空电话亭周边点位。",
      "高威胁委托通常伴随精英敌人、环境伤害和倒计时目标，队伍中至少保留一个生存位。",
      "完成委托后立刻清理周边收集物，部分隐藏宝箱、谕石提示和拍照点会在异象解除后显现。"
    ],
    tipsEn: [
      "Record trigger windows, weather and prerequisite interactions first so you do not repeatedly check empty phone-booth areas.",
      "High-threat commissions often include elites, environmental damage and timed objectives, so keep at least one survival slot in the team.",
      "After a commission is cleared, immediately check nearby collectibles because hidden chests, oracle stone prompts and photo spots may appear after the anomaly fades."
    ]
  }
];
---

<BaseLayout
  title="新手资源规划与城区机制 | 异环"
  description="异环开荒体力分配、日常优先级、抽卡取舍、城区探索、车辆改装和版本复查指南。"
  jsonLd={{ "@context": "https://schema.org", "@type": "CollectionPage", name: "异环机制与新手指南" }}
>
  <header class="max-w-4xl">
    <p class="text-sm font-semibold text-neon" data-i18n="guides.kicker">新手资源规划与城区机制</p>
    <h1 class="text-3xl font-black" data-i18n="guides.title">通用机制 / 新手指南</h1>
    <p class="mt-3 text-sm leading-6 text-zinc-600 dark:text-zinc-400">
      这里收纳新手期最容易用得上的判断：体力先刷什么、日常委托怎么排、抽卡停手线怎么设、城区路线怎么补，以及哪些结论需要在版本更新后重新检查。
    </p>
  </header>

  <section class="mt-8 grid gap-4 lg:grid-cols-[1.15fr_0.85fr]">
    <article class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-glow">
      <p class="text-sm font-semibold text-teal-600 dark:text-neon">推荐先看</p>
      <h2 class="mt-2 text-2xl font-black text-zinc-950 dark:text-white">
        <a class="hover:text-teal-600 dark:hover:text-neon" href={featuredGuide ? `/guides/${featuredGuide.slug}/` : "/guides/"}>
          {featuredGuide?.data.title || "新手入门与资源规划"}
        </a>
      </h2>
      <p class="mt-3 text-sm leading-7 text-zinc-600 dark:text-zinc-400">
        这篇指南把开荒资源、每日优先级、体力顺序、抽卡取舍和版本复查串成一条实际可执行的路线，适合第一次整理队伍和材料分配时阅读。
      </p>
      <div class="mt-5 flex flex-wrap gap-2">
        <span class="rounded-md border border-zinc-200 bg-zinc-50 px-3 py-1.5 text-xs font-semibold text-zinc-600 dark:border-line dark:bg-black/20 dark:text-zinc-300">开荒资源规划</span>
        <span class="rounded-md border border-zinc-200 bg-zinc-50 px-3 py-1.5 text-xs font-semibold text-zinc-600 dark:border-line dark:bg-black/20 dark:text-zinc-300">每日优先级</span>
        <span class="rounded-md border border-zinc-200 bg-zinc-50 px-3 py-1.5 text-xs font-semibold text-zinc-600 dark:border-line dark:bg-black/20 dark:text-zinc-300">体力使用顺序</span>
        <span class="rounded-md border border-zinc-200 bg-zinc-50 px-3 py-1.5 text-xs font-semibold text-zinc-600 dark:border-line dark:bg-black/20 dark:text-zinc-300">抽卡与养成取舍</span>
      </div>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href={featuredGuide ? `/guides/${featuredGuide.slug}/` : "/guides/"} class="rounded-lg border border-neon/60 px-4 py-2 text-sm font-semibold text-neon transition hover:bg-neon hover:text-black">
          阅读完整指南
        </a>
        <a href="/explore/" class="rounded-lg border border-zinc-200 px-4 py-2 text-sm font-semibold text-zinc-700 transition hover:border-teal-600 hover:text-teal-600 dark:border-line dark:text-zinc-200 dark:hover:text-neon">
          先看探索页
        </a>
      </div>
    </article>

    <div class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
      <p class="text-sm font-semibold text-teal-600 dark:text-neon">指南状态</p>
      <div class="mt-4 space-y-3">
        {guides.map((g) => (
          <div class="rounded-lg border border-zinc-200 bg-zinc-50 p-4 dark:border-line dark:bg-black/20">
            <a href={`/guides/${g.slug}/`} class="font-bold text-zinc-950 hover:text-neon dark:text-white">
              {g.data.title}
            </a>
            <p class="mt-2 text-sm leading-6 text-zinc-600 dark:text-zinc-400">{g.data.description}</p>
            <p class="mt-2 text-xs text-zinc-500">最后更新：{g.data.updatedAt}</p>
          </div>
        ))}
      </div>
      <div class="mt-5 rounded-lg border border-teal-200 bg-teal-50 p-4 dark:border-neon/30 dark:bg-neon/10">
        <p class="text-xs font-semibold uppercase text-teal-600 dark:text-neon">下一步</p>
        <p class="mt-2 text-sm leading-6 text-zinc-700 dark:text-zinc-200">
          先看完整新手指南，再用抽卡计算器核对资源阈值，最后回到探索页检查有没有漏掉会影响开荒路线的内容。
        </p>
        <a href="/tools/gacha-calculator/" class="mt-3 inline-flex text-sm font-semibold text-teal-700 hover:text-teal-900 dark:text-neon dark:hover:text-white">
          打开抽卡计算器
        </a>
      </div>
    </div>
  </section>

  <section class="mt-10 space-y-8">
    {
      systems.map((system, index) => {
        const reverse = index % 2 === 1;

        return (
          <article class="grid items-center gap-6 md:grid-cols-2">
            <div class={`relative overflow-hidden rounded-xl border border-neon/70 bg-black/30 p-2 shadow-glow ${reverse ? "md:order-2" : ""}`}>
              <span class="absolute left-5 top-5 z-10 rounded-md border border-neon/50 bg-black/55 px-3 py-1 text-xs font-semibold text-neon backdrop-blur">
                <span data-i18n={`guides.tag.${system.tagKey}`}>{system.tag}</span>
              </span>
              <img
                src={system.image}
                alt={system.alt}
                class="aspect-[16/9] w-full rounded-lg object-cover"
                loading="lazy"
              />
            </div>

            <div class={reverse ? "md:order-1" : ""}>
              <h3 class="text-2xl font-bold text-zinc-950 dark:text-white" data-i18n={`guides.system.${system.key}`}>{system.name}</h3>
              <ul class="mt-4 space-y-3 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
                {system.tips.map((tip, tipIndex) => (
                  <li class="rounded-lg border border-zinc-200 bg-white/70 p-3 dark:border-line dark:bg-white/[0.04]">
                    <span class="lang-zh">{tip}</span>
                    <span class="lang-en">{system.tipsEn[tipIndex]}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        );
      })
    }
  </section>
</BaseLayout>
