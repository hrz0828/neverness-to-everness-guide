---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { guideVisuals } from "../data/guideVisuals";

const guideOrder = [
  "character-tier-list",
  "team-comps",
  "growth-material-route",
  "banner-analysis-framework",
  "boss-combat-guide",
  "exploration-checklist",
  "systems-overview",
  "first-30-days-route",
  "faq",
  "version-review-checklist",
  "beginner",
  "team-building",
  "anomaly-commission-checklist",
  "gacha-budget",
  "daily-weekly-priority"
];
const getGuideOrder = (slug) => {
  const index = guideOrder.indexOf(slug);
  return index === -1 ? guideOrder.length : index;
};
const guides = [...await getCollection("guides")].sort((a, b) => getGuideOrder(a.slug) - getGuideOrder(b.slug));
const guideMeta = {
  "character-tier-list": { category: "角色养成", tag: "练谁", time: "6 分钟" },
  "team-comps": { category: "角色养成", tag: "配队", time: "7 分钟" },
  "team-building": { category: "角色养成", tag: "循环", time: "5 分钟" },
  "growth-material-route": { category: "抽卡资源", tag: "养成", time: "6 分钟" },
  "banner-analysis-framework": { category: "抽卡资源", tag: "卡池", time: "6 分钟" },
  "gacha-budget": { category: "抽卡资源", tag: "预算", time: "5 分钟" },
  "beginner": { category: "新手入门", tag: "开荒", time: "6 分钟" },
  "first-30-days-route": { category: "新手入门", tag: "30天", time: "7 分钟" },
  "daily-weekly-priority": { category: "新手入门", tag: "日常", time: "5 分钟" },
  "faq": { category: "新手入门", tag: "FAQ", time: "4 分钟" },
  "boss-combat-guide": { category: "探索战斗", tag: "BOSS", time: "6 分钟" },
  "exploration-checklist": { category: "探索战斗", tag: "查漏", time: "6 分钟" },
  "anomaly-commission-checklist": { category: "探索战斗", tag: "异象", time: "5 分钟" },
  "systems-overview": { category: "系统机制", tag: "机制", time: "6 分钟" },
  "version-review-checklist": { category: "系统机制", tag: "版本", time: "5 分钟" }
};
const guideGroups = [
  { name: "新手入门", desc: "刚入坑、回坑或想整理账号节奏时先看这里。", slugs: ["beginner", "first-30-days-route", "daily-weekly-priority", "faq"] },
  { name: "角色养成", desc: "解决练谁、怎么配队、循环不顺和材料投入的问题。", slugs: ["character-tier-list", "team-comps", "team-building"] },
  { name: "抽卡资源", desc: "抽卡前先算预算，养成时再看材料和方斯消耗。", slugs: ["banner-analysis-framework", "gacha-budget", "growth-material-route"] },
  { name: "探索战斗", desc: "地图查漏、异象委托和高压战斗卡关时使用。", slugs: ["exploration-checklist", "anomaly-commission-checklist", "boss-combat-guide"] },
  { name: "系统机制", desc: "看不懂系统名词或版本内容变化时快速补课。", slugs: ["systems-overview", "version-review-checklist"] }
].map((group) => ({
  ...group,
  guides: group.slugs.map((slug) => guides.find((guide) => guide.slug === slug)).filter(Boolean)
}));
const featuredGuides = ["beginner", "character-tier-list", "exploration-checklist"]
  .map((slug) => guides.find((guide) => guide.slug === slug))
  .filter(Boolean);

const systems = [
  {
    key: "city",
    tagKey: "explore",
    name: "城市异象探索",
    tag: "探索必看",
    image: "/images/news/area-illusion-town.jpg",
    alt: "异环城市异象探索街区游戏截图",
    tips: [
      "优先解锁城区传送点，再回头清理屋顶、地下通道和高架夹层的隐藏收集。",
      "夜间巡逻和雨后街区更容易遇到高威胁异象委托，建议提前准备治疗位和控场角色。",
      "遇到空间扭曲、信号噪点或路灯异常闪烁时，先沿街角、屋顶入口和桥下层寻找调查交互点。"
    ],
    tipsEn: [
      "Unlock district teleports first, then return for hidden collectibles on rooftops, underground paths and elevated layers.",
      "Night patrols and rainy districts are more likely to surface high-threat anomaly commissions, so prepare healing and control before entering.",
      "When space distortion, signal noise or abnormal streetlights appear, check street corners, rooftop access points and under-bridge layers for investigation prompts."
    ]
  },
  {
    key: "car",
    tagKey: "hot",
    name: "改装车系统",
    tag: "热门机制",
    image: "/images/news/area-new-herland.jpg",
    alt: "异环改装车系统城市道路游戏截图",
    tips: [
      "开荒期优先升级操控、加速和耐久，能显著提升跑图效率和追逐任务容错。",
      "城区探索建议携带高机动配置，材料循环路线则更适合续航和稳定性配件。",
      "部分追逐、限时取样和异常封锁会限制步行路径，改装车可作为快速脱离异常区域的关键工具。"
    ],
    tipsEn: [
      "During progression, upgrade handling, acceleration and durability first to improve travel efficiency and chase-task tolerance.",
      "Use high-mobility setups for city exploration, and endurance or stability parts for material routes.",
      "Some chase tasks, timed sampling routes and abnormal lockdowns restrict walking routes, so tuned vehicles can be the safest way to exit quickly."
    ]
  },
  {
    key: "events",
    tagKey: "advanced",
    name: "异象委托追踪",
    tag: "进阶路线",
    image: "/images/news/city-gameplay.jpg",
    alt: "异环都市街道异象委托追踪游戏截图",
    tips: [
      "先记录异象委托的触发时段、天气和前置交互，避免反复跑空电话亭周边点位。",
      "高威胁委托通常伴随精英敌人、环境伤害和倒计时目标，队伍中至少保留一个生存位。",
      "完成委托后立刻清理周边收集物，部分隐藏宝箱、谕石提示和拍照点会在异象解除后显现。"
    ],
    tipsEn: [
      "Record trigger windows, weather and prerequisite interactions first so you do not repeatedly check empty phone-booth areas.",
      "High-threat commissions often include elites, environmental damage and timed objectives, so keep at least one survival slot in the team.",
      "After a commission is cleared, immediately check nearby collectibles because hidden chests, oracle stone prompts and photo spots may appear after the anomaly fades."
    ]
  }
];
---

<BaseLayout
  title="新手资源规划与城区机制 | 异环"
  description="异环开荒体力、日常周常、抽卡养成、城区探索、车辆改装和版本内容指南。"
  jsonLd={{ "@context": "https://schema.org", "@type": "CollectionPage", name: "异环机制与新手指南" }}
>
  <header class="max-w-3xl">
    <p class="text-sm font-semibold text-neon" data-i18n="guides.kicker">开荒、养成、探索与抽卡</p>
    <h1 class="text-3xl font-black leading-tight text-zinc-950 dark:text-white sm:text-4xl" data-i18n="guides.title">异环攻略指南</h1>
    <p class="mt-3 text-base leading-7 text-zinc-600 dark:text-zinc-400">
      不知道先练谁、体力刷什么、卡池要不要抽，或者探索度卡住时，从这里按问题找攻略。
    </p>
  </header>

  <section class="mt-8">
    <div class="mb-4 flex items-end justify-between gap-4">
      <div>
        <p class="text-sm font-semibold text-teal-600 dark:text-neon">推荐先看</p>
        <h2 class="mt-1 text-2xl font-black text-zinc-950 dark:text-white">从最常见的问题开始</h2>
      </div>
      <a href="/tools/gacha-calculator/" class="hidden text-sm font-semibold text-teal-700 hover:text-teal-900 dark:text-neon dark:hover:text-white sm:inline">
        打开抽卡计算器
      </a>
    </div>
    <div class="grid gap-4 lg:grid-cols-3">
      {featuredGuides.map((guide, index) => {
        const meta = guideMeta[guide.slug];
        const visual = guideVisuals[guide.slug];
        return (
          <a
            href={`/guides/${guide.slug}/`}
            class:list={[
              "group block rounded-lg border bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-teal-500 hover:shadow-md dark:bg-panel/80 dark:hover:border-neon dark:hover:shadow-glow",
              index === 0 ? "border-teal-300 dark:border-neon/60" : "border-zinc-200 dark:border-line"
            ]}
          >
            <div class="relative -mx-1 -mt-1 overflow-hidden rounded-md">
              <img src={visual?.image} alt={visual?.alt || guide.data.title} class="aspect-[16/9] w-full object-cover transition duration-300 group-hover:scale-[1.03]" loading={index === 0 ? "eager" : "lazy"} />
              <div class="absolute inset-x-0 bottom-0 flex items-end justify-between gap-3 bg-gradient-to-t from-black/80 to-transparent p-3 text-xs font-semibold">
                <span class="rounded-md bg-black/55 px-2.5 py-1 text-neon backdrop-blur">{meta?.tag}</span>
                <span class="text-zinc-200">{meta?.time}</span>
              </div>
            </div>
            <h3 class="mt-4 min-h-[3.25rem] text-xl font-black leading-snug text-zinc-950 group-hover:text-teal-700 dark:text-white dark:group-hover:text-neon">
              {guide.data.title}
            </h3>
            <p class="mt-3 line-clamp-2 min-h-[3.5rem] text-sm leading-7 text-zinc-600 dark:text-zinc-400">
              {guide.data.description}
            </p>
          </a>
        );
      })}
    </div>
  </section>

  <section class="mt-10 space-y-8">
    {guideGroups.map((group) => (
      <section>
        <div class="mb-4 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <h2 class="text-2xl font-black text-zinc-950 dark:text-white">{group.name}</h2>
            <p class="mt-1 max-w-2xl text-sm leading-6 text-zinc-600 dark:text-zinc-400">{group.desc}</p>
          </div>
        </div>
        <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
          {group.guides.map((guide) => {
            const meta = guideMeta[guide.slug];
            const visual = guideVisuals[guide.slug];
            return (
              <a
                href={`/guides/${guide.slug}/`}
                class="group grid min-h-[18rem] content-between overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm transition hover:border-teal-500 hover:bg-teal-50/40 dark:border-line dark:bg-panel/70 dark:hover:border-neon dark:hover:bg-white/[0.05]"
              >
                <div>
                  <div class="relative overflow-hidden">
                    <img src={visual?.image} alt={visual?.alt || guide.data.title} class="aspect-[16/9] w-full object-cover transition duration-300 group-hover:scale-[1.03]" loading="lazy" />
                    <div class="absolute left-3 top-3 rounded-md bg-black/60 px-2 py-1 text-xs font-semibold text-neon backdrop-blur">{meta?.tag}</div>
                  </div>
                  <div class="px-4 pt-4">
                    <div class="mb-2 flex items-center justify-between gap-3 text-xs">
                      <span class="font-semibold text-teal-700 dark:text-neon">{meta?.category}</span>
                      <span class="text-zinc-500">{meta?.time}</span>
                    </div>
                    <h3 class="line-clamp-2 text-lg font-bold leading-snug text-zinc-950 group-hover:text-teal-700 dark:text-white dark:group-hover:text-neon">
                      {guide.data.title}
                    </h3>
                    <p class="mt-2 line-clamp-2 text-sm leading-6 text-zinc-600 dark:text-zinc-400">
                      {guide.data.description}
                    </p>
                  </div>
                </div>
                <p class="px-4 pb-4 pt-3 text-xs text-zinc-500">最后更新：{guide.data.updatedAt}</p>
              </a>
            );
          })}
        </div>
      </section>
    ))}
  </section>

  <section class="mt-10 space-y-8">
    {
      systems.map((system, index) => {
        const reverse = index % 2 === 1;

        return (
          <article class="grid items-center gap-6 md:grid-cols-2">
            <div class={`relative overflow-hidden rounded-xl border border-neon/70 bg-black/30 p-2 shadow-glow ${reverse ? "md:order-2" : ""}`}>
              <span class="absolute left-5 top-5 z-10 rounded-md border border-neon/50 bg-black/55 px-3 py-1 text-xs font-semibold text-neon backdrop-blur">
                <span data-i18n={`guides.tag.${system.tagKey}`}>{system.tag}</span>
              </span>
              <img
                src={system.image}
                alt={system.alt}
                class="aspect-[16/9] w-full rounded-lg object-cover"
                loading="lazy"
              />
            </div>

            <div class={reverse ? "md:order-1" : ""}>
              <h3 class="text-2xl font-bold text-zinc-950 dark:text-white" data-i18n={`guides.system.${system.key}`}>{system.name}</h3>
              <ul class="mt-4 space-y-3 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
                {system.tips.map((tip, tipIndex) => (
                  <li class="rounded-lg border border-zinc-200 bg-white/70 p-3 dark:border-line dark:bg-white/[0.04]">
                    <span class="lang-zh">{tip}</span>
                    <span class="lang-en">{system.tipsEn[tipIndex]}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        );
      })
    }
  </section>
</BaseLayout>
