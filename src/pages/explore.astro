---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const maps = await getCollection("maps");
---

<BaseLayout
  title="地图/探索攻略 | 异环"
  description="异环都市区域隐藏收集、异象事件触发条件、材料路线与探索清单。"
  jsonLd={{ "@context": "https://schema.org", "@type": "CollectionPage", name: "异环地图探索攻略" }}
>
  <h1 class="text-3xl font-black">地图/探索攻略</h1>
  <p class="mt-2 max-w-2xl text-zinc-400">按城区拆分隐藏收集、异象事件、材料点位和推荐路线。</p>

  <div class="mt-6 grid gap-4 md:grid-cols-2">
    {
      maps.map((m) => (
        <article class="card">
          <img src={m.data.cover} alt={m.data.title} loading="lazy" class="aspect-[16/9] w-full rounded-md object-cover" />
          <h2 class="mt-3 font-bold">{m.data.title}</h2>
          <p class="mt-2 text-sm leading-6 text-zinc-400">{m.data.description}</p>
        </article>
      ))
    }
  </div>
</BaseLayout>
