---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { mapEnglish } from "../../data/contentEnglish";

export async function getStaticPaths() {
  const maps = await getCollection("maps");
  return maps.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const english = mapEnglish[entry.slug];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  image: new URL(entry.data.cover, Astro.site).toString(),
  dateModified: entry.data.updatedAt
};
---

<BaseLayout
  title={`${entry.data.title} | 异环地图探索`}
  description={entry.data.description}
  ogImage={entry.data.cover}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-5xl">
    <nav class="text-sm text-zinc-500">
      <a href="/" class="hover:text-neon">首页</a>
      <span class="mx-2">/</span>
      <a href="/explore/" class="hover:text-neon">地图探索</a>
      <span class="mx-2">/</span>
      <span class="text-zinc-300">{entry.data.title}</span>
    </nav>

    <header class="mt-6 overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-glow">
      <div class="grid gap-0 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="relative min-h-72 overflow-hidden bg-zinc-100 dark:bg-[#07090f]">
          <img
            src={entry.data.cover}
            alt={`${entry.data.title}封面图`}
            class="absolute inset-0 size-full object-cover"
            loading="eager"
          />
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/85 via-black/25 to-transparent p-4">
            <span class="rounded-md bg-neon px-3 py-1 text-xs font-black text-black">
              {entry.data.region || "探索路线"}
            </span>
          </div>
        </div>

        <div class="p-5 sm:p-6">
          <p class="text-sm font-semibold text-neon">Map Guide</p>
          <h1 class="mt-2 text-3xl font-black leading-tight text-zinc-950 dark:text-white sm:text-5xl">
            {entry.data.title}
          </h1>
          <p class="mt-4 text-sm leading-7 text-zinc-600 dark:text-zinc-300">{entry.data.description}</p>

          <div class="mt-5 flex flex-wrap gap-4 text-sm text-zinc-500">
            <span>最后更新：{entry.data.updatedAt}</span>
            <span>区域：{entry.data.region || "探索路线"}</span>
          </div>

          <div class="mt-6 grid gap-3">
            <div class="rounded-lg border border-zinc-200 bg-zinc-50 p-4 dark:border-line dark:bg-black/20">
              <p class="text-xs font-semibold uppercase text-teal-600 dark:text-neon">推荐顺序</p>
              <p class="mt-2 text-sm leading-7 text-zinc-700 dark:text-zinc-300">{entry.data.priority}</p>
            </div>
            <div class="rounded-lg border border-zinc-200 bg-zinc-50 p-4 dark:border-line dark:bg-black/20">
              <p class="text-xs font-semibold uppercase text-teal-600 dark:text-neon">路线摘要</p>
              <ol class="mt-3 space-y-2 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
                {entry.data.route.map((step, index) => (
                  <li class="flex gap-3">
                    <span class="grid size-6 shrink-0 place-items-center rounded-md bg-teal-500 text-xs font-black text-white dark:bg-neon dark:text-black">
                      {index + 1}
                    </span>
                    <span>{step}</span>
                  </li>
                ))}
              </ol>
            </div>
          </div>
        </div>
      </div>
    </header>

    <section class="mt-6 grid gap-4 md:grid-cols-2">
      <div class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
        <h2 class="text-sm font-bold text-zinc-950 dark:text-white">收集清单</h2>
        <ul class="mt-3 space-y-2 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
          {entry.data.checklist.map((item) => (
            <li class="rounded-lg border border-zinc-200 bg-zinc-50 p-3 dark:border-line dark:bg-black/20">{item}</li>
          ))}
        </ul>
      </div>

      <div class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
        <h2 class="text-sm font-bold text-zinc-950 dark:text-white">异象提示</h2>
        <ul class="mt-3 space-y-2 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
          {entry.data.events.map((event) => (
            <li class="rounded-lg border border-teal-200 bg-teal-50 p-3 dark:border-neon/30 dark:bg-neon/10">{event}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="mt-4 grid gap-4 md:grid-cols-2">
      <div class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
        <h2 class="text-sm font-bold text-zinc-950 dark:text-white">补漏避坑</h2>
        <ul class="mt-3 space-y-2 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
          {entry.data.warnings.map((warning) => (
            <li class="rounded-lg border border-amber/40 bg-amber/10 p-3">{warning}</li>
          ))}
        </ul>
      </div>

      <div class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
        <h2 class="text-sm font-bold text-zinc-950 dark:text-white">相关推荐</h2>
        <div class="mt-3 flex flex-wrap gap-3">
          <a href="/explore/" class="rounded-lg border border-neon/60 px-4 py-2 text-sm font-semibold text-neon transition hover:bg-neon hover:text-black">返回探索页</a>
          <a href="/guides/" class="rounded-lg border border-zinc-200 px-4 py-2 text-sm font-semibold text-zinc-700 transition hover:border-neon hover:text-neon dark:border-line dark:text-zinc-300">查看新手指南</a>
        </div>
      </div>
    </section>

    <section class="prose mt-8 max-w-none dark:prose-invert prose-headings:scroll-mt-24">
      <Content />
    </section>

    {english?.body && (
      <section class="character-guide lang-en mt-8">
        <div class="prose max-w-none dark:prose-invert prose-headings:scroll-mt-24" set:html={english.body} />
      </section>
    )}
  </article>
</BaseLayout>
