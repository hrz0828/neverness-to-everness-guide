---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { mapEnglish } from "../../data/contentEnglish";

export async function getStaticPaths() {
  const maps = await getCollection("maps");
  return maps.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const english = mapEnglish[entry.slug];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.description,
  image: new URL(entry.data.cover, Astro.site).toString(),
  dateModified: entry.data.updatedAt
};
---

<BaseLayout
  title={`${entry.data.title} | 异环地图探索`}
  description={entry.data.description}
  ogImage={entry.data.cover}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-5xl">
    <nav class="text-sm text-zinc-500">
      <a href="/" class="hover:text-neon"><span class="lang-zh">首页</span><span class="lang-en">Home</span></a>
      <span class="mx-2">/</span>
      <a href="/explore/" class="hover:text-neon"><span class="lang-zh">地图探索</span><span class="lang-en">Map Exploration</span></a>
      <span class="mx-2">/</span>
      <span class="text-zinc-300"><span class="lang-zh">{entry.data.title}</span><span class="lang-en">{english?.title || entry.data.title}</span></span>
    </nav>

    <header class="mt-6 overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-glow">
      <div class="grid gap-0 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="relative min-h-72 overflow-hidden bg-zinc-100 dark:bg-[#07090f]">
          <img
            src={entry.data.cover}
            alt={`${entry.data.title}封面图`}
            class="absolute inset-0 size-full object-cover"
            loading="eager"
          />
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/85 via-black/25 to-transparent p-4">
            <span class="rounded-md bg-neon px-3 py-1 text-xs font-black text-black">
              <span class="lang-zh">{entry.data.region || "探索路线"}</span>
              <span class="lang-en">{english?.region || "Exploration Route"}</span>
            </span>
          </div>
        </div>

        <div class="p-5 sm:p-6">
          <p class="text-sm font-semibold text-neon">Map Guide</p>
          <h1 class="mt-2 text-3xl font-black leading-tight text-zinc-950 dark:text-white sm:text-5xl">
            <span class="lang-zh">{entry.data.title}</span>
            <span class="lang-en">{english?.title || entry.data.title}</span>
          </h1>
          <p class="mt-4 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
            <span class="lang-zh">{entry.data.description}</span>
            <span class="lang-en">{english?.description || entry.data.description}</span>
          </p>

          <div class="mt-5 flex flex-wrap gap-4 text-sm text-zinc-500">
            <span><span class="lang-zh">最后更新：</span><span class="lang-en">Updated: </span>{entry.data.updatedAt}</span>
            <span><span class="lang-zh">区域：{entry.data.region || "探索路线"}</span><span class="lang-en">Region: {english?.region || "Exploration Route"}</span></span>
          </div>

          <div class="mt-6 grid gap-3">
            <div class="rounded-lg border border-zinc-200 bg-zinc-50 p-4 dark:border-line dark:bg-black/20">
              <p class="text-xs font-semibold uppercase text-teal-600 dark:text-neon"><span class="lang-zh">推荐顺序</span><span class="lang-en">Recommended Order</span></p>
              <p class="mt-2 text-sm leading-7 text-zinc-700 dark:text-zinc-300"><span class="lang-zh">{entry.data.priority}</span><span class="lang-en">{english?.priority || entry.data.priority}</span></p>
            </div>
            <div class="rounded-lg border border-zinc-200 bg-zinc-50 p-4 dark:border-line dark:bg-black/20">
              <p class="text-xs font-semibold uppercase text-teal-600 dark:text-neon"><span class="lang-zh">路线摘要</span><span class="lang-en">Route Summary</span></p>
              <ol class="mt-3 space-y-2 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
                {entry.data.route.map((step, index) => (
                  <li class="flex gap-3">
                    <span class="grid size-6 shrink-0 place-items-center rounded-md bg-teal-500 text-xs font-black text-white dark:bg-neon dark:text-black">
                      {index + 1}
                    </span>
                    <span><span class="lang-zh">{step}</span><span class="lang-en">{english?.route[index] || step}</span></span>
                  </li>
                ))}
              </ol>
            </div>
          </div>
        </div>
      </div>
    </header>

    <section class="mt-6 grid gap-4 md:grid-cols-2">
      <div class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
        <h2 class="text-sm font-bold text-zinc-950 dark:text-white"><span class="lang-zh">收集清单</span><span class="lang-en">Collection Checklist</span></h2>
        <ul class="mt-3 space-y-2 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
          {entry.data.checklist.map((item, index) => (
            <li class="rounded-lg border border-zinc-200 bg-zinc-50 p-3 dark:border-line dark:bg-black/20"><span class="lang-zh">{item}</span><span class="lang-en">{english?.checklist[index] || item}</span></li>
          ))}
        </ul>
      </div>

      <div class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
        <h2 class="text-sm font-bold text-zinc-950 dark:text-white"><span class="lang-zh">异象提示</span><span class="lang-en">Anomaly Notes</span></h2>
        <ul class="mt-3 space-y-2 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
          {entry.data.events.map((event, index) => (
            <li class="rounded-lg border border-teal-200 bg-teal-50 p-3 dark:border-neon/30 dark:bg-neon/10"><span class="lang-zh">{event}</span><span class="lang-en">{english?.events[index] || event}</span></li>
          ))}
        </ul>
      </div>
    </section>

    <section class="mt-4 grid gap-4 md:grid-cols-2">
      <div class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
        <h2 class="text-sm font-bold text-zinc-950 dark:text-white"><span class="lang-zh">补漏避坑</span><span class="lang-en">Cleanup Pitfalls</span></h2>
        <ul class="mt-3 space-y-2 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
          {entry.data.warnings.map((warning, index) => (
            <li class="rounded-lg border border-amber/40 bg-amber/10 p-3"><span class="lang-zh">{warning}</span><span class="lang-en">{english?.warnings[index] || warning}</span></li>
          ))}
        </ul>
      </div>

      <div class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
        <h2 class="text-sm font-bold text-zinc-950 dark:text-white"><span class="lang-zh">相关推荐</span><span class="lang-en">Related Links</span></h2>
        <div class="mt-3 flex flex-wrap gap-3">
          <a href="/explore/" class="rounded-lg border border-neon/60 px-4 py-2 text-sm font-semibold text-neon transition hover:bg-neon hover:text-black"><span class="lang-zh">返回探索页</span><span class="lang-en">Back to Explore</span></a>
          <a href="/guides/" class="rounded-lg border border-zinc-200 px-4 py-2 text-sm font-semibold text-zinc-700 transition hover:border-neon hover:text-neon dark:border-line dark:text-zinc-300"><span class="lang-zh">查看新手指南</span><span class="lang-en">View Beginner Guides</span></a>
        </div>
      </div>
    </section>

    <section class="prose lang-zh mt-8 max-w-none dark:prose-invert prose-headings:scroll-mt-24">
      <Content />
    </section>

    {english?.body && (
      <section class="character-guide lang-en mt-8">
        <div class="prose max-w-none dark:prose-invert prose-headings:scroll-mt-24" set:html={english.body} />
      </section>
    )}
  </article>
</BaseLayout>
