---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { characterEnglish } from "../../data/contentEnglish";

export async function getStaticPaths() {
  const chars = await getCollection("characters");
  return chars.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const english = characterEnglish[entry.slug];
const coverPositions = {
  anhunqu: "object-[73%_center]",
  jiuyuan: "object-[73%_center]",
  nanally: "object-[72%_center]",
  xun: "object-[82%_center]"
};
const coverPositionClass = coverPositions[entry.slug] || "object-center";
const quickFacts = [
  { label: "稀有度", labelEn: "Rarity", value: entry.data.rarity },
  { label: "属性", labelEn: "Element", value: entry.data.element, valueEn: english?.element },
  { label: "定位", labelEn: "Role", value: entry.data.role, valueEn: english?.role },
  { label: "武器", labelEn: "Weapon", value: entry.data.weapon, valueEn: english?.weapon }
];
const buildFocus = entry.data.description
  .replace(/^《异环》/, "")
  .split("，")
  .slice(0, 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: `${entry.data.title} 角色攻略`,
  description: entry.data.description,
  image: new URL(entry.data.cover, Astro.site).toString(),
  dateModified: entry.data.updatedAt
};
---

<BaseLayout
  title={`${entry.data.title} 角色攻略 | 异环`}
  description={entry.data.description}
  ogImage={entry.data.cover}
  jsonLd={jsonLd}
>
  <article>
    <header class="grid overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-glow lg:grid-cols-[minmax(0,1fr)_24rem]">
      <div class="flex flex-col justify-between p-5 sm:p-6">
        <div>
          <p class="text-sm font-semibold text-teal-600 dark:text-neon">角色攻略 / {entry.data.element}属性</p>
          <h1 class="mt-2 text-4xl font-black text-zinc-950 dark:text-white">{entry.data.title}</h1>
          <p class="lang-zh mt-3 max-w-3xl text-sm leading-7 text-zinc-600 dark:text-zinc-300">{entry.data.description}</p>
          {english && <p class="lang-en mt-3 max-w-3xl text-sm leading-7 text-zinc-600 dark:text-zinc-300">{english.description}</p>}
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-4">
          {quickFacts.map((fact) => (
            <div class="rounded-lg border border-zinc-200 bg-zinc-50 p-3 dark:border-line dark:bg-black/20">
              <p class="text-xs text-zinc-500"><span class="lang-zh">{fact.label}</span><span class="lang-en">{fact.labelEn}</span></p>
              <p class="lang-zh mt-1 text-sm font-bold text-zinc-950 dark:text-white">{fact.value}</p>
              <p class="lang-en mt-1 text-sm font-bold text-zinc-950 dark:text-white">{fact.valueEn || fact.value}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="relative min-h-80 overflow-hidden bg-zinc-100 dark:bg-[#07090f]">
        <img
          src={entry.data.cover}
          alt={`异环角色-${entry.data.title}立绘`}
          class:list={["absolute inset-0 size-full object-cover", coverPositionClass]}
          loading="eager"
        />
        <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/85 via-black/25 to-transparent p-5">
          <div class="flex flex-wrap gap-2">
            <span class="rounded-md bg-neon px-3 py-1 text-xs font-black text-black">{entry.data.rarity}</span>
            <span class="rounded-md border border-white/30 bg-black/45 px-3 py-1 text-xs font-semibold text-white">
              {entry.data.role}
            </span>
          </div>
        </div>
      </div>
    </header>

    <section class="mt-6 rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
      <p class="text-sm font-semibold text-teal-600 dark:text-neon"><span class="lang-zh">养成速览</span><span class="lang-en">Build Snapshot</span></p>
      <div class="mt-4 grid gap-3 md:grid-cols-3">
        {buildFocus.map((focus) => (
          <div class="lang-zh rounded-lg border border-teal-200 bg-teal-50 p-3 text-sm leading-6 text-zinc-700 dark:border-neon/30 dark:bg-neon/10 dark:text-zinc-200">
            {focus}
          </div>
        ))}
        {english && (
          <div class="lang-en rounded-lg border border-teal-200 bg-teal-50 p-3 text-sm leading-6 text-zinc-700 dark:border-neon/30 dark:bg-neon/10 dark:text-zinc-200">
            {english.role}
          </div>
        )}
      </div>
    </section>

    <div class="character-guide lang-zh mt-8">
      <Content />
    </div>
    {english && <div class="character-guide lang-en mt-8" set:html={english.html} />}
  </article>
</BaseLayout>
