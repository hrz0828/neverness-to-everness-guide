---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../site.config";
import { newsItems } from "../data/news";
import { characterNameEnglish, newsEnglish } from "../data/contentEnglish";

const featuredCharacters = [
  {
    key: "xun",
    name: "浔",
    role: "光属性 / 爆发副C",
    image: "/images/characters/xun.png",
    imagePosition: "object-[82%_center]",
    alt: "异环角色-浔立绘",
    desc: "浔围绕“非闭合时计”运转，通过记录队友变轨技或援护技，并在10秒时停窗口复现技能、切换太刀形态打出高额爆发。",
    href: "/characters/xun/"
  },
  {
    key: "anhunqu",
    name: "安魂曲",
    role: "暗属性 / DOT站场主C",
    image: "/images/characters/anhunqu.png",
    imagePosition: "object-[73%_center]",
    alt: "异环角色-安魂曲立绘",
    desc: "安魂曲围绕噩梦DOT、双形态输出和拟态学习运转，适合已有早雾、法帝娅或达芙蒂尔体系的玩家作为暗属性主C投入。",
    href: "/characters/anhunqu/"
  },
  {
    key: "jiuyuan",
    name: "九原",
    role: "灵属性 / 聚怪副C",
    image: "/images/characters/jiuyuan.png",
    imagePosition: "object-[73%_center]",
    alt: "异环角色-九原立绘",
    desc: "九原围绕致命玫约标记与清算爆发运转，兼具大范围聚怪、速切输出和灵属性队伍联动，是开荒与高难都值得投入的常驻S级角色。",
    href: "/characters/jiuyuan/"
  }
];

const newsCards = [...newsItems].sort((a, b) => b.date.localeCompare(a.date)).slice(0, 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "异环中文攻略站",
  url: Astro.site?.toString() || siteConfig.url,
  potentialAction: {
    "@type": "SearchAction",
    target: `${new URL("search/", Astro.site || siteConfig.url).toString()}?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};
---

<BaseLayout
  title="异环攻略站 | Neverness to Everness 中文指南"
  description="高质量 NTE 中文攻略站：角色培养、地图探索、机制解析、版本资讯与抽卡养成工具。"
  ogImage="/og-cover.webp"
  jsonLd={jsonLd}
>
  <section class="relative min-h-[calc(100vh-7rem)] overflow-hidden rounded-xl border border-line">
    <img
      src="/images/news/nte-main-poster.jpg"
      alt="异环都市开放世界游戏主视觉"
      class="absolute inset-0 size-full object-cover"
      fetchpriority="high"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/95 via-black/70 to-black/35"></div>
    <div class="relative flex min-h-[calc(100vh-7rem)] max-w-3xl flex-col justify-center px-5 py-16 sm:px-8">
      <p class="mb-3 text-sm font-semibold text-neon" data-i18n="home.hero.kicker">Neverness to Everness / NTE</p>
      <h1 class="text-4xl font-black leading-tight text-white drop-shadow-[0_2px_18px_rgba(0,0,0,0.65)] sm:text-6xl" data-i18n="home.hero.title">
        当城市偏离常理，异能就是唯一坐标。
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-7 text-zinc-200" data-i18n="home.hero.desc">
        欢迎来到《异环》中文攻略站。这里记录赫麦诺都市中的角色养成、电话亭与谕石路线、异象委托、抽卡预算和版本机制，帮助调查员在霓虹、裂隙与反常异象之间找到可执行的路线。
      </p>
      <form action="/search/" class="mt-6 flex max-w-xl gap-2">
        <input
          name="q"
          class="min-w-0 flex-1 rounded-lg border border-line bg-black/55 px-3 py-3 text-sm text-zinc-100 placeholder:text-zinc-400 outline-none focus:border-neon"
          placeholder="搜索安魂曲、九原、地图路线、抽卡预算"
          data-i18n-placeholder="home.search.placeholder"
        />
        <button class="rounded-lg bg-neon px-4 py-3 text-sm font-bold text-black" data-i18n="home.search.button">搜索</button>
      </form>
    </div>
  </section>

  <section class="mt-10">
    <div class="mb-4 flex items-end justify-between gap-4">
      <h2 class="text-2xl font-bold" data-i18n="home.characters.title">推荐角色</h2>
      <a href="/characters/" class="text-sm text-neon" data-i18n="home.characters.more">查看全部角色</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {
        featuredCharacters.map((character) => (
          <a
            href={character.href}
            class="card group block transition duration-300 hover:-translate-y-1 hover:border-neon hover:bg-white/[0.06]"
          >
            <div class="overflow-hidden rounded-xl">
              <img
                src={character.image}
                alt={character.alt}
                class:list={[
                  "aspect-[4/5] w-full object-cover transition duration-300 group-hover:scale-105",
                  character.imagePosition || "object-center"
                ]}
                loading="lazy"
              />
            </div>
            <div class="mt-4">
              <p class="text-xs font-semibold text-neon" data-i18n={`home.character.${character.key}.role`}>{character.role}</p>
              <h3 class="mt-1 text-xl font-bold transition group-hover:text-blue-400">
                <span class="lang-zh">{character.name}</span>
                <span class="lang-en">{characterNameEnglish[character.key] || character.name}</span>
              </h3>
              <p class="mt-2 text-sm leading-6 text-zinc-400" data-i18n={`home.character.${character.key}.desc`}>{character.desc}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mt-10">
    <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold text-neon">
          <span class="lang-zh">玩法体验评价</span>
          <span class="lang-en">Gameplay Reviews</span>
        </p>
        <h2 class="text-2xl font-bold text-zinc-950 dark:text-white">
          <span class="lang-zh">基于公开资料，评价各类玩法到底好不好玩</span>
          <span class="lang-en">Subjective gameplay reviews based on public coverage</span>
        </h2>
      </div>
      <a href="/guides/" class="text-sm text-neon">
        <span class="lang-zh">查看全部指南</span>
        <span class="lang-en">All Guides</span>
      </a>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      <a href="/guides/city-exploration-play-experience/" class="card group grid gap-4 overflow-hidden transition duration-300 hover:-translate-y-1 hover:border-neon hover:bg-white/[0.06] sm:grid-cols-[0.9fr_1.1fr]">
        <img src="/images/news/area-illusion-town.jpg" alt="异环城市探索与异象街区体验" class="aspect-[16/10] w-full rounded-lg object-cover sm:h-full" loading="lazy" />
        <div>
          <p class="text-xs font-semibold text-neon"><span class="lang-zh">开放世界 / 生活玩法评测</span><span class="lang-en">Open World / Life Systems Review</span></p>
          <h3 class="mt-2 text-xl font-bold transition group-hover:text-blue-400">
            <span class="lang-zh">城市与生活玩法体验评价</span>
            <span class="lang-en">City and Life Gameplay Review</span>
          </h3>
          <p class="mt-2 text-sm leading-6 text-zinc-400">
            <span class="lang-zh">结合评测和上线反馈，评价开放城市、载具、异常事件、经营小游戏和生活互动的实际体验。</span>
            <span class="lang-en">Evaluates open-city play, vehicles, anomalies, business mini-games and life interactions using reviews and launch coverage.</span>
          </p>
        </div>
      </a>

      <a href="/guides/combat-growth-play-experience/" class="card group grid gap-4 overflow-hidden transition duration-300 hover:-translate-y-1 hover:border-neon hover:bg-white/[0.06] sm:grid-cols-[0.9fr_1.1fr]">
        <img src="/images/news/city-gameplay.jpg" alt="异环城市战斗与角色养成体验" class="aspect-[16/10] w-full rounded-lg object-cover sm:h-full" loading="lazy" />
        <div>
          <p class="text-xs font-semibold text-neon"><span class="lang-zh">战斗 / 养成 / 抽卡评测</span><span class="lang-en">Combat / Growth / Gacha Review</span></p>
          <h3 class="mt-2 text-xl font-bold transition group-hover:text-blue-400">
            <span class="lang-zh">战斗、养成与抽卡体验评价</span>
            <span class="lang-en">Combat, Growth and Gacha Review</span>
          </h3>
          <p class="mt-2 text-sm leading-6 text-zinc-400">
            <span class="lang-zh">结合公开评测和玩法资料，评价动作手感、队伍构筑、弧盘词条、BOSS和长期日常压力。</span>
            <span class="lang-en">Reviews action feel, team building, Arcs, modules, bosses, banners and long-term daily pressure from public coverage.</span>
          </p>
        </div>
      </a>
    </div>
  </section>

  <section class="lang-zh mt-10 rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-semibold text-neon">开荒路线 / 资源决策</p>
        <h2 class="text-2xl font-bold text-zinc-950 dark:text-white">先定体力和抽卡，再按城区补电话亭与谕石</h2>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-zinc-600 dark:text-zinc-400">
          新手先用资源规划确认体力优先级，再用抽卡工具写好停手线；地图补漏则按维特海默塔、ReroRero 电话亭、谕石、屋顶和桥下夹层推进，避免在同一区域反复绕路。
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/guides/beginner/" class="rounded-lg border border-neon/60 px-4 py-2 text-sm font-semibold text-neon transition hover:bg-neon hover:text-black">开荒资源规划</a>
        <a href="/explore/" class="rounded-lg border border-zinc-200 px-4 py-2 text-sm font-semibold text-zinc-700 transition hover:border-neon hover:text-neon dark:border-line dark:text-zinc-300">城区补漏路线</a>
        <a href="/tools/gacha-calculator/" class="rounded-lg border border-zinc-200 px-4 py-2 text-sm font-semibold text-zinc-700 transition hover:border-neon hover:text-neon dark:border-line dark:text-zinc-300">抽卡停手线计算</a>
      </div>
    </div>
  </section>

  <section class="lang-en mt-10 rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80 dark:shadow-none">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-semibold text-neon">Progression Route / Resource Decisions</p>
        <h2 class="text-2xl font-bold text-zinc-950 dark:text-white">Set stamina and pull plans before cleaning city routes</h2>
        <p class="mt-2 max-w-3xl text-sm leading-6 text-zinc-600 dark:text-zinc-400">
          New accounts should start with resource planning, then define a pull stop line. For exploration cleanup, unlock towers and phone booths first, then sweep oracle stones, rooftops and under-bridge layers by district.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="/guides/beginner/" class="rounded-lg border border-neon/60 px-4 py-2 text-sm font-semibold text-neon transition hover:bg-neon hover:text-black">Beginner Planning</a>
        <a href="/explore/" class="rounded-lg border border-zinc-200 px-4 py-2 text-sm font-semibold text-zinc-700 transition hover:border-neon hover:text-neon dark:border-line dark:text-zinc-300">City Cleanup Routes</a>
        <a href="/tools/gacha-calculator/" class="rounded-lg border border-zinc-200 px-4 py-2 text-sm font-semibold text-zinc-700 transition hover:border-neon hover:text-neon dark:border-line dark:text-zinc-300">Pull Stop-Line Calculator</a>
      </div>
    </div>
  </section>

  <section class="lang-zh mt-10 grid gap-5 lg:grid-cols-[1fr_1fr]">
    <article class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80">
      <p class="text-sm font-semibold text-teal-700 dark:text-neon">本站原创整理方法</p>
      <h2 class="mt-2 text-2xl font-black text-zinc-950 dark:text-white">把公告、实测和玩家反馈整理成可执行路线</h2>
      <div class="mt-4 space-y-3 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
        <p>
          本站不是简单搬运游戏公告。每篇攻略会先确定读者问题，例如“新号第一周体力刷什么”“探索度卡在 92% 怎么查漏”“抽卡预算不足时先停哪里”，再把公开信息、游戏内验证、路线截图和玩家反馈整理成步骤。
        </p>
        <p>
          对版本敏感的结论会保留判断依据：角色攻略说明循环与投入顺序，地图攻略按地面、地下、屋顶和高架分层，抽卡工具把保底、剩余天数和活动补票拆开计算。这样即使版本调整，读者也能知道应复查哪一项。
        </p>
        <p>
          我们会优先维护能直接影响账号决策的内容，短消息会合并到专题页，未确认信息不会单独做成占位页面。
        </p>
        <p>
          新版本上线后，会先检查卡池规则、地图奖励、角色循环和工具参数，再更新相关推荐入口和首页提示。
        </p>
      </div>
    </article>

    <article class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80">
      <p class="text-sm font-semibold text-teal-700 dark:text-neon">适合先看的攻略路径</p>
      <h2 class="mt-2 text-2xl font-black text-zinc-950 dark:text-white">按账号阶段选择入口，避免在列表页来回跳转</h2>
      <ol class="mt-4 space-y-3 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
        <li class="rounded-md border border-zinc-200 bg-zinc-50 p-3 dark:border-line dark:bg-black/20">
          新号或回坑：先读 <a href="/guides/beginner/">开荒资源规划</a> 和 <a href="/guides/first-30-days-route/">前 30 天路线</a>，确认体力、方斯、技能书和弧盘材料的优先级。
        </li>
        <li class="rounded-md border border-zinc-200 bg-zinc-50 p-3 dark:border-line dark:bg-black/20">
          准备抽卡：打开 <a href="/tools/gacha-calculator/">抽卡计算器</a>，再对照 <a href="/guides/banner-analysis-framework/">卡池分析框架</a> 写好本体、弧盘和停手线。
        </li>
        <li class="rounded-md border border-zinc-200 bg-zinc-50 p-3 dark:border-line dark:bg-black/20">
          探索补漏：从 <a href="/explore/">地图探索页</a> 进入区域路线，优先补电话亭、谕石、桥下夹层、屋顶入口和异象解除后的隐藏交互。
        </li>
      </ol>
    </article>
  </section>

  <section class="lang-en mt-10 grid gap-5 lg:grid-cols-[1fr_1fr]">
    <article class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80">
      <p class="text-sm font-semibold text-teal-700 dark:text-neon">How We Create Original Guide Content</p>
      <h2 class="mt-2 text-2xl font-black text-zinc-950 dark:text-white">Turning notices, testing and player feedback into practical routes</h2>
      <div class="mt-4 space-y-3 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
        <p>
          This site is not a copy of game announcements. Each guide starts with a real player question, such as what to spend stamina on during week one, how to fix a stuck exploration percentage, or when to stop pulling on a banner.
        </p>
        <p>
          Version-sensitive advice keeps its reasoning visible. Character guides explain rotations and investment order, map guides separate ground, underground, rooftop and elevated layers, and the calculator separates pity, remaining days and event income.
        </p>
        <p>
          We prioritize pages that help account decisions. Short news items are merged into topic guides, unconfirmed information is not published as a standalone placeholder page, and homepage recommendations are reviewed after version changes.
        </p>
      </div>
    </article>

    <article class="rounded-lg border border-zinc-200 bg-white p-5 shadow-sm dark:border-line dark:bg-panel/80">
      <p class="text-sm font-semibold text-teal-700 dark:text-neon">Recommended Reading Path</p>
      <h2 class="mt-2 text-2xl font-black text-zinc-950 dark:text-white">Choose a route by account stage</h2>
      <ol class="mt-4 space-y-3 text-sm leading-7 text-zinc-600 dark:text-zinc-300">
        <li class="rounded-md border border-zinc-200 bg-zinc-50 p-3 dark:border-line dark:bg-black/20">
          New or returning accounts should start with <a href="/guides/beginner/">beginner resource planning</a> and the <a href="/guides/first-30-days-route/">first 30 days route</a> to set stamina and skill-material priorities.
        </li>
        <li class="rounded-md border border-zinc-200 bg-zinc-50 p-3 dark:border-line dark:bg-black/20">
          Before pulling, open the <a href="/tools/gacha-calculator/">gacha calculator</a> and compare it with the <a href="/guides/banner-analysis-framework/">banner analysis framework</a> to define a stop line.
        </li>
        <li class="rounded-md border border-zinc-200 bg-zinc-50 p-3 dark:border-line dark:bg-black/20">
          For exploration cleanup, start from the <a href="/explore/">map hub</a> and clear phone booths, oracle stones, under-bridge layers, rooftops and post-anomaly interactions by district.
        </li>
      </ol>
    </article>
  </section>

  <section class="mt-10">
    <div class="mb-4 flex items-end justify-between gap-4">
      <h2 class="text-2xl font-bold" data-i18n="home.news.title">最新攻略/版本动态</h2>
      <a href="/news/" class="text-sm text-neon" data-i18n="home.news.more">更多</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {
        newsCards.map((news) => (
          <a
            href={`/news/${news.id}/`}
            class="card group block transition duration-300 hover:-translate-y-1 hover:border-neon hover:bg-white/[0.06]"
          >
            <img
              src={news.image}
              alt={`异环攻略封面-${news.title}`}
              class="aspect-[16/9] w-full rounded-lg object-cover"
              loading="lazy"
            />
            <div class="mt-4 flex flex-wrap gap-2 text-xs text-zinc-500">
              <span>{news.date}</span>
              <span><span class="lang-zh">{news.category || "攻略更新"}</span><span class="lang-en">{newsEnglish[news.id]?.category || "Guide Update"}</span></span>
            </div>
            <h3 class="mt-2 font-bold transition group-hover:text-blue-400"><span class="lang-zh">{news.title}</span><span class="lang-en">{newsEnglish[news.id]?.title}</span></h3>
            <p class="mt-2 text-sm leading-6 text-zinc-400"><span class="lang-zh">{news.excerpt}</span><span class="lang-en">{newsEnglish[news.id]?.excerpt}</span></p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
