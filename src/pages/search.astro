---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="站内搜索 | 异环攻略站"
  description="搜索异环角色攻略、地图探索、机制指南、材料路线和版本更新。"
  jsonLd={{ "@context": "https://schema.org", "@type": "SearchResultsPage", name: "异环站内搜索" }}
>
  <h1 class="text-3xl font-black">站内搜索</h1>
  <div id="search" class="mt-6"></div>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script>
    window.addEventListener("DOMContentLoaded", () => {
      // Pagefind assets are generated by `npm run build`.
      new PagefindUI({
        element: "#search",
        showSubResults: true,
        translations: {
          placeholder: "输入关键词，如：安缇娅、雷系、异象事件"
        }
      });
    });
  </script>
</BaseLayout>
