---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import SeoHead from "../components/SeoHead.astro";
import Sidebar from "../components/Sidebar.astro";
import I18nScript from "../components/I18nScript.astro";
import { siteConfig } from "../site.config";

const { title, description, ogImage = "/og-cover.webp", jsonLd } = Astro.props;
---

<html lang="zh-CN" class="dark" data-lang="zh">
  <head>
    <SeoHead title={title} description={description} ogImage={ogImage} jsonLd={jsonLd} />
  </head>
  <body>
    <Nav />
    <Sidebar />
    <main class="mx-auto max-w-7xl px-4 pb-16 pt-24 lg:pl-72">
      <slot />
      <footer class="mt-14 border-t border-line pt-6 text-sm text-zinc-500">
        <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
          <p>© 2026 <span data-i18n="site.name">{siteConfig.name}</span>. <span data-i18n="footer.note">玩家自建攻略站，非游戏官方网站。</span></p>
          <nav class="flex flex-wrap gap-x-4 gap-y-2">
            <a href="/about/" data-i18n="footer.about">关于本站</a>
            <a href="/contact/" data-i18n="footer.contact">联系我们</a>
            <a href="/editorial-policy/" data-i18n="footer.editorial">编辑准则</a>
            <a href="/privacy/" data-i18n="footer.privacy">隐私政策</a>
            <a href="/disclaimer/" data-i18n="footer.disclaimer">免责声明</a>
          </nav>
        </div>
      </footer>
    </main>
    <I18nScript />
  </body>
</html>
